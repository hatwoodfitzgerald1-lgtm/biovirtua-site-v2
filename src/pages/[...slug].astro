---
export const prerender = false;
// Bundle every generated page as a raw string at build time (reference recipe).
const files = import.meta.glob('../site/**/index.html', { query: '?raw', import: 'default', eager: true });
const map = {};
for (const p in files) {
  let r = p.replace('../site', '').replace(/index\.html$/, '');
  if (r === '') r = '/';
  map[r] = files[p];
}
let path = new URL(Astro.request.url).pathname;
if (!path.endsWith('/')) path += '/';
let html = map[path];
if (!html) {
  // Tolerate a Webflow mount prefix (/app/plans/ -> /plans/) only with a real second segment.
  const parts = path.split('/').filter(Boolean);
  if (parts.length >= 2) html = map['/' + parts.slice(1).join('/') + '/'];
}
const notFound = !html;
if (notFound) html = map['/404/'] || map['/'];
return new Response(html, {
  status: notFound ? 404 : 200,
  headers: { 'content-type': 'text/html; charset=utf-8' }
});
---
